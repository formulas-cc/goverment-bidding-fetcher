# ============================================================
# 北京中建云智政府采购网（ZJCY）凭证
# 通过 govb-fetcher --set-cookie 自动写入，或手动填写
# ============================================================
FETCHER_ZJCY_BEARER_TOKEN=your-bearer-token-here
FETCHER_ZJCY_TBSESSION=your-ygcg-tbsession-here
FETCHER_ZJCY_JSESSIONID=your-jsessionid-here
FETCHER_ZJCY_ALB_ROUTE=your-alb-route-here

# ============================================================
# 后续新增数据源凭证示例（按 FETCHER_{SOURCE}_{PARAM} 命名）
# ============================================================
# FETCHER_CCGP_TOKEN=xxx          # 中国政府采购网
# FETCHER_CCGP_SESSION=xxx

# ============================================================
# 通用关键词配置（所有数据源共享，逗号分隔）
# ============================================================
FETCHER_KEYWORDS=体系,模型,仿真,数据,决策,规划,分析,智能,AI,软件,系统,信息,算法,效能
FETCHER_EXCLUDE_KEYWORDS=体能,训练鞋,鞋类,服装,被装,医疗,药品,器械,膝关节,光纤,电梯,物业,绿化,装修,工程,建材,食材,食品,副食
FETCHER_HIGH_VALUE_KEYWORDS=模型,仿真,数据,决策,分析,智能,AI,软件,意向

# ============================================================
# 输出目录
# ============================================================
FETCHER_OUTPUT_DIR=~/.openclaw/workspace/govb-fetcher
